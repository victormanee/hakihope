{
  "name": "@lovable.dev/vite-tanstack-config",
  "version": "2.7.6",
  "description": "Vite config wrapper for Lovable TanStack Start projects",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "keywords": [
    "vite",
    "tanstack",
    "lovable",
    "config"
  ],
  "license": "MIT",
  "dependencies": {
    "@lovable.dev/vite-plugin-dev-server-bridge": "^1.1.1",
    "@lovable.dev/vite-plugin-hmr-gate": "^1.1.3",
    "@tanstack/devtools-vite": "^0.8.1",
    "lightningcss": "^1.30.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0 <9.0.0",
    "@tailwindcss/vite": ">=4.0.0",
    "vite-tsconfig-paths": ">=6.0.0",
    "nitro": ">=3.0.260603-beta",
    "@tanstack/react-start": ">=1.100.0",
    "@vitejs/plugin-react": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "nitro": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-start": "^1.167.50",
    "@types/node": "22.13.13",
    "@vitejs/plugin-react": "^5.2.0",
    "nitro": "3.0.260603-beta",
    "rimraf": "^5.0.0",
    "tsdown": "^0.22.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lovablelabs/lovable.git",
    "directory": "npm-packages/lovable-vite-tanstack"
  },
  "scripts": {
    "build": "tsdown",
    "check:package": "tmp=$(mktemp -d) && pnpm pack --out \"$tmp/pkg.tgz\" && tar -xzf \"$tmp/pkg.tgz\" -C \"$tmp\" && publint \"$tmp/package\" --strict && attw \"$tmp/pkg.tgz\"",
    "typecheck": "tsgo --noEmit",
    "dev": "tsdown --watch",
    "test": "vitest",
    "clean": "rimraf dist",
    "coverage": "vitest run --coverage"
  }
}